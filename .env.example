# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Copy this file to .env for local development:
#   cp .env.example .env
#   (then fill in your real values)
#
# !! NEVER commit .env to Git — it contains secrets !!
# Make sure .env is listed in your .gitignore
#
# Set these same variables in Netlify:
#   Netlify dashboard → Site settings → Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Shared secret that every Marblism webhook request must include.
# Marblism sends this as:  Authorization: Bearer <this value>
#
# Generate a strong secret with:
#   openssl rand -hex 32
# or:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace-this-with-a-long-random-string

# GitHub Personal Access Token (classic) with the "repo" scope.
# Generate one at: https://github.com/settings/tokens → "Generate new token (classic)"
# Check the box labelled "repo" (full repository access) and nothing else.
GITHUB_TOKEN=ghp_replace_this_with_your_real_token

# ── OPTIONAL (pre-filled with your project defaults) ──────────────────────────

# Your GitHub username — already set to your account
GITHUB_OWNER=nexusluma365

# Your repository name — already set to your blog repo
GITHUB_REPO=NaphtaliBryant

# The branch Netlify watches and auto-deploys from
GITHUB_BRANCH=main

# Fallback author name used when Marblism doesn't send one
DEFAULT_AUTHOR=Naphtali Bryant

# Set to "true" to save ALL incoming posts as drafts by default.
# Individual payloads can still override this with "draft": false.
# Set to "false" (or leave empty) to auto-publish everything.
